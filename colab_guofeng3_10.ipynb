   "source": [
    "# 🏯 10张测试 · 国风3 (GuoFeng3 XL)\n",
    "## Colab + GuoFeng3 + ControlNet Canny\n",
    "\n",
    "使用时严格排除女性化 → 专注男性历史人物"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 1. 安装\n",
    "!pip install diffusers transformers accelerate xformers pillow controlnet-aux -q\n",
    "import torch, os, json, time, gc\n",
    "from pathlib import Path\n",
    "from PIL import Image, ImageDraw\n",
    "from diffusers import StableDiffusionXLControlNetPipeline, ControlNetModel\n",
    "from controlnet_aux import CannyDetector\n",
    "print(f\"GPU: {torch.cuda.get_device_name(0)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 2. 挂载 Drive\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "DRIVE = Path(\"/content/drive/MyDrive\")\n",
    "\n",
    "# 找 guofeng3 模型文件\n",
    "models = list(DRIVE.glob(\"*guofeng*\")) + list(DRIVE.glob(\"*GuoFeng*\")) + list(DRIVE.glob(\"*.safetensors\"))\n",
    "if not models:\n",
    "    print(\"❌ 没找到模型！请下载 GuoFeng3_XL.safetensors 上传到 Google Drive\")\n",
    "    print(\"下载: https://civitai.com/models/10415/guofeng3\")\n",
    "else:\n",
    "    print(f\"✅ 找到模型: {models[0].name}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 3. 10张卡牌\n",
    "cards = [\n",
    "    {\"card_id\":\"QH-P-0001-L05\",\"name\":\"秦始皇\",\"type\":\"person\",\"dynasty\":\"秦汉\",\"tags\":[\"帝王\",\"秦朝\",\"统一\",\"长城\"],\"story\":\"秦始皇嬴政，中国历史上第一位皇帝，统一六国，建立中央集权制度。\"},\n",
    "    {\"card_id\":\"SG-P-0002-L04\",\"name\":\"关羽\",\"type\":\"person\",\"dynasty\":\"三国\",\"tags\":[\"五虎将\",\"忠义\",\"武圣\"],\"story\":\"关羽，蜀汉五虎将之首，被后世尊为武圣关帝。\"},\n",
    "    {\"card_id\":\"ST-P-0001-L05\",\"name\":\"李世民\",\"type\":\"person\",\"dynasty\":\"隋唐\",\"tags\":[\"唐朝\",\"帝王\",\"贞观之治\"],\"story\":\"唐太宗李世民，开创贞观之治的一代明君。\"},\n",
    "    {\"card_id\":\"QH-E-0017-L03\",\"name\":\"鸿门宴\",\"type\":\"event\",\"dynasty\":\"秦汉\",\"tags\":[\"楚汉\",\"宴会\",\"项羽\",\"刘邦\"],\"story\":\"项羽设宴鸿门欲杀刘邦，刘邦在张良樊哙帮助下化险为夷。\"},\n",
    "    {\"card_id\":\"SG-E-0018-L04\",\"name\":\"赤壁之战\",\"type\":\"event\",\"dynasty\":\"三国\",\"tags\":[\"火攻\",\"周瑜\",\"曹操\"],\"story\":\"赤壁之战孙刘联军火烧曹船，奠定三国鼎立格局。\"},\n",
    "    {\"card_id\":\"QH-L-0004-L01\",\"name\":\"咸阳\",\"type\":\"place\",\"dynasty\":\"秦汉\",\"tags\":[\"秦都\",\"关中\",\"宫殿\"],\"story\":\"咸阳是秦朝都城，中国历史上第一座大一统帝国首都。\"},\n",
    "    {\"card_id\":\"SG-L-0001-L01\",\"name\":\"赤壁\",\"type\":\"place\",\"dynasty\":\"三国\",\"tags\":[\"长江\",\"火攻\",\"古战场\"],\"story\":\"赤壁之战火烧连船，三国鼎立格局从此奠定。\"},\n",
    "    {\"card_id\":\"QH-W-0025-L03\",\"name\":\"天子剑\",\"type\":\"weapon\",\"dynasty\":\"秦汉\",\"tags\":[\"帝王\",\"宝剑\",\"象征\"],\"story\":\"天子剑象征皇权至高无上，秦始皇佩剑为太阿剑。\"},\n",
    "    {\"card_id\":\"QH-B-0029-L03\",\"name\":\"九章算术\",\"type\":\"classic\",\"dynasty\":\"秦汉\",\"tags\":[\"数学\",\"汉代\",\"科学\"],\"story\":\"九章算术是汉代最终成书的中国古代最重要的数学经典。\"},\n",
    "    {\"card_id\":\"QH-D-0035-L05\",\"name\":\"大秦帝国\",\"type\":\"dynasty\",\"dynasty\":\"秦汉\",\"tags\":[\"秦朝\",\"帝国\",\"统一\"],\"story\":\"大秦帝国是中国历史上第一个大一统王朝。\"},\n",
    "]\n",
    "print(f\"📋 {len(cards)} 张\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 4. 加载国风3\n",
    "canny = CannyDetector()\n",
    "model_path = str(list(DRIVE.glob(\"*.safetensors\"))[0])\n",
    "print(f\"📦 {Path(model_path).name}\")\n",
    "\n",
    "cn = ControlNetModel.from_pretrained(\"diffusers/controlnet-canny-sdxl-1.0\", torch_dtype=torch.float16)\n",
    "pipe = StableDiffusionXLControlNetPipeline.from_single_file(model_path, controlnet=cn, torch_dtype=torch.float16, use_safetensors=True)\n",
    "pipe = pipe.to(\"cuda\")\n",
    "pipe.enable_xformers_memory_efficient_attention()\n",
    "print(\"✅ 加载完成!\"); gc.collect(); torch.cuda.empty_cache()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 5. 提示词（强力排除女性）\n",
    "def mkp(c):\n",
    "    n = c[\"name\"]; t = c[\"type\"]; d = c.get(\"dynasty\",\"\")\n",
    "    tags = \", \".join(c.get(\"tags\",[])[:4]) if isinstance(c.get(\"tags\"), list) else \"\"\n",
    "    b = \"masterpiece, best quality, highly detailed, 2d illustration, Chinese historical art style\"\n",
    "    T = {\n",
    "        \"person\": f\"{b}, 1boy, solo, {n}, {d} dynasty Chinese emperor general, {tags}, masculine man, short beard, thick eyebrows, stern face, wearing traditional Chinese dragon robe or armor, hanfu, ancient Chinese court background, Chinese ink painting style\",\n",
    "        \"event\": f\"{b}, {n}, {d} dynasty historical battle, {tags}, ancient Chinese armies, warriors in armor, dramatic scene, Chinese historical painting, epic\",\n",
    "        \"place\": f\"{b}, scenery, {n}, {d} dynasty ancient Chinese landmark, {tags}, grand architecture, palaces, city walls, misty mountains, no humans, Chinese ink landscape\",\n",
    "        \"weapon\": f\"{b}, {n}, {d} dynasty ancient Chinese weapon, {tags}, ornate metalwork, still life, no humans, displayed on dark silk, museum quality Lighting\",\n",
    "        \"classic\": f\"{b}, {n}, {d} dynasty ancient Chinese book, {tags}, bamboo slips, scrolls, ink brush, warm candlelight, no humans, scholarly still life\",\n",
    "        \"book\": f\"{b}, {n}, {d} dynasty ancient Chinese book, {tags}, bamboo slips, scrolls, ink brush, warm candlelight, no humans, scholarly still life\",\n",
    "        \"dynasty\": f\"{b}, {n}, {d} dynasty Chinese imperial symbol, {tags}, dragon, jade seal, golden palace, Great Wall, majestic, epic\",\n",
    "    }\n",
    "    return T.get(t, T[\"person\"])\n",
    "\n",
    "# 👇 强力负面词 —— 彻底排除女性和不想要的特征\n",
    "NEG = (\"1girl, female, woman, girl, lady, feminine, girly, makeup, lipstick, long eyelashes, \"\n",
    "       \"bishounen, pretty boy, androgynous, soft face, smooth skin, young, \"\n",
    "       \"3d, realistic, photo, photograph, photorealistic, \"\n",
    "       \"western, european, modern clothing, gun, \"\n",
    "       \"text, watermark, signature, username, \"\n",
    "       \"lowres, worst quality, ugly, deformed, blurry, bad anatomy, extra fingers\")")
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 6. 🚀 生成\n",
    "OUT = DRIVE / \"card_guofeng3_test\"\n",
    "OUT.mkdir(exist_ok=True)\n",
    "\n",
    "for i, c in enumerate(cards):\n",
    "    cid, name, ctype = c[\"card_id\"], c[\"name\"], c[\"type\"]\n",
    "    out = OUT / f\"{cid}.png\"\n",
    "    if out.exists():\n",
    "        print(f\"[{i+1}/10] {name} ✓\"); continue\n",
    "    \n",
    "    print(f\"\\n[{i+1}/10] {name} ({ctype})\")\n",
    "    try:\n",
    "        # 构图画布\n",
    "        ref = Image.new(\"RGB\",(832,1216),(45,40,35))\n",
    "        draw = ImageDraw.Draw(ref)\n",
    "        if ctype in (\"person\",\"event\"):\n",
    "            draw.ellipse((340,150,492,310), outline=(120,100,80), width=5)\n",
    "            draw.rectangle((312,310,520,750), outline=(120,100,80), width=5)\n",
    "        elif ctype == \"place\":\n",
    "            draw.rectangle((80,380,380,950), outline=(120,100,80), width=5)\n",
    "            draw.polygon([(60,380),(230,160),(400,380)], outline=(120,100,80), width=5)\n",
    "        elif ctype in (\"weapon\",\"classic\",\"book\"):\n",
    "            draw.line((416,120,416,980), fill=(120,100,80), width=6)\n",
    "        \n",
    "        edge = canny(ref, low_threshold=50, high_threshold=150)\n",
    "        prompt = mkp(c)\n",
    "        \n",
    "        r = pipe(prompt=prompt, negative_prompt=NEG, image=edge,\n",
    "                 controlnet_conditioning_scale=0.85,\n",
    "                 num_inference_steps=30, guidance_scale=6.5,\n",
    "                 width=832, height=1216).images[0]\n",
    "        r.save(out)\n",
    "        print(f\"  ✅\")\n",
    "        gc.collect(); torch.cuda.empty_cache()\n",
    "    except Exception as e:\n",
    "        print(f\"  ❌ {str(e)[:80]}\")\n",
    "\n",
    "print(f\"\\n🎉 {len(list(OUT.glob('*.png')))}/10 完成! → Drive/card_guofeng3_test/\")"
   ]
  }
 ],
